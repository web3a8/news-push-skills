# 加密密钥（首次运行时自动生成）
NEWS_PUSH_ENCRYPTION_KEY=your-encryption-key-here

# 默认 AI 配置（可选）
NEWS_PUSH_DEFAULT_AI_PROVIDER=claude
NEWS_PUSH_DEFAULT_AI_API_KEY=your-api-key-here
NEWS_PUSH_DEFAULT_AI_MODEL=claude-3-sonnet-20240229

# 数据库路径
NEWS_PUSH_DB_PATH=~/.news_push/db.sqlite

# 日志级别
NEWS_PUSH_LOG_LEVEL=INFO
