# SMTP 邮件发送配置
# 以 QQ 邮箱为例，其他邮箱替换 SMTP_HOST 即可

# SMTP 服务器地址
#   QQ邮箱:     smtp.qq.com
#   163邮箱:    smtp.163.com
#   Gmail:      smtp.gmail.com
#   Outlook:    smtp.office365.com
SMTP_HOST=smtp.qq.com

# SMTP 端口 (SSL)
SMTP_PORT=465

# 登录邮箱地址
SMTP_USER=your-email@qq.com

# 授权码 (不是登录密码)
#   QQ邮箱:  设置 → 账户 → POP3/SMTP服务 → 生成授权码
#   163邮箱: 设置 → POP3/SMTP/IMAP → 新增授权密码
#   Gmail:   账号 → 安全 → 应用专用密码
SMTP_PASS=your-authorization-code

# 收件人地址 (多人用英文逗号分隔)
EMAIL_TO=target@example.com
